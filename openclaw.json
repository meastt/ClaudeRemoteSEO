{
  "_schema": "openclaw-config",
  "_version": "3.4.26",
  "workspace": {
    "name": "tigertribe-seo-agency",
    "site": "https://tigertribe.net/",
    "niche": "scientific zoological research — predatory felids",
    "auth_profiles_file": "./auth-profiles.json"
  },
  "tools": {
    "profile": "full",
    "deny": ["apply_patch"]
  },
  "tiered_intelligence_routing": {
    "roles": {
      "Analyst": {
        "model_id": "gemini-3.1-pro-preview",
        "provider_profile": "google_ai",
        "tier": "light",
        "default_params": {
          "max_tokens": 4096,
          "temperature": 0.3
        }
      },
      "Writer_Draft": {
        "model_id": "gemini-3.1-flash-lite-preview",
        "provider_profile": "google_ai",
        "tier": "draft",
        "default_params": {
          "max_tokens": 8192,
          "temperature": 0.5
        }
      },
      "Writer_Polish": {
        "model_id": "anthropic/claude-sonnet-4-6",
        "provider_profile": "anthropic",
        "tier": "heavy",
        "default_params": {
          "max_tokens": 4096,
          "temperature": 0.4
        }
      },
      "Technician": {
        "model_id": "gemini-3.1-flash-lite-preview",
        "provider_profile": "google_ai",
        "tier": "light",
        "default_params": {
          "max_tokens": 2048,
          "temperature": 0.1
        }
      },
      "QAGate": {
        "model_id": "claude-haiku-4-5-20251001",
        "provider_profile": "anthropic",
        "tier": "light",
        "default_params": {
          "max_tokens": 1024,
          "temperature": 0.1
        }
      },
      "ArtDirector": {
        "model_id": "gemini-3.1-flash-image",
        "provider_profile": "google_ai",
        "tier": "image",
        "default_params": {
          "aspectRatio": "16:9",
          "numberOfImages": 1
        }
      }
    },
    "failover_chain": {
      "trigger_codes": [
        429,
        500,
        502,
        503,
        504
      ],
      "strategy": "sequential",
      "chain": [
        {
          "step": 1,
          "label": "Primary",
          "resolve": "role_default"
        },
        {
          "step": 2,
          "label": "OpenRouter Failover",
          "provider_profile": "openrouter",
          "model_map": {
            "Analyst": "anthropic/claude-3.5-sonnet",
            "Writer_Draft": "google/gemini-flash-2.5",
            "Writer_Polish": "anthropic/claude-3.5-sonnet",
            "Technician": "google/gemini-flash-1.5"
          }
        }
      ],
      "max_failover_attempts": 2,
      "alert_on_failover": true,
      "alert_channel": "telegram"
    }
  },
  "channel_adapters": {
    "telegram": {
      "provider_profile": "telegram",
      "enabled": true,
      "bot_name": "TigerTribe_SEO_bot",
      "multi_workspace": {
        "enabled": false
      }
    },
    "wordpress_rest": {
      "provider_profile": "wordpress",
      "enabled": true,
      "permitted_actions": [
        "GET",
        "POST",
        "PUT"
      ]
    }
  },
  "hooks": {
    "before_tool_call": {
      "qa_gate": {
        "path": "./hooks/qa-before-publish.js",
        "tools": ["wordpress_rest"],
        "methods": ["POST", "PUT"]
      }
    }
  },
  "memory": {
    "backend": "mmr",
    "index": "tigertribe-content-index",
    "fields_indexed": [
      "post_id",
      "slug",
      "title",
      "last_updated_at",
      "primary_keyword",
      "secondary_keywords"
    ],
    "query": {
      "hybrid": {
        "vectorWeight": 0.7,
        "textWeight": 0.3,
        "candidateMultiplier": 4,
        "mmr": { "lambda": 0.7 },
        "temporalDecay": { "halfLifeDays": 30 }
      }
    }
  }
}
